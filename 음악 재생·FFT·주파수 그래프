#nullable disable
using NAudio.Dsp;
using NAudio.Wave;
using System;
using System.Drawing;
using System.Drawing.Drawing2D;
using System.IO;
using System.Windows.Forms;

namespace num1_Project
{
    public partial class MainForm
    {
        private sealed class VisualizerSampleProvider : ISampleProvider
        {
            private readonly ISampleProvider _source;
            private readonly Action<float> _onSample;

            public VisualizerSampleProvider(ISampleProvider source, Action<float> onSample)
            {
                _source = source;
                _onSample = onSample;
            }

            public WaveFormat WaveFormat => _source.WaveFormat;

            public int Read(float[] buffer, int offset, int count)
            {
                int read = _source.Read(buffer, offset, count);
                for (int i = 0; i < read; i++)
                    _onSample(buffer[offset + i]);
                return read;
            }
        }

        private async void PlaySong(int index)
        {
            if (index < 0 || index >= _playlist.Count)
                return;

            try
            {
                StopPlayback();

                _currentIndex = index;
                _currentSong = _playlist[index];

                string localPath = await DatabaseHelper.DownloadSongToCacheAsync(_currentSong);

                if (string.IsNullOrWhiteSpace(localPath) || !File.Exists(localPath))
                {
                    MessageBox.Show("파일을 찾을 수 없습니다.", "재생 오류");
                    return;
                }

                _audioReader = new AudioFileReader(localPath);
                _waveOut = new WaveOutEvent();

                var sampleProvider = _audioReader.ToSampleProvider();
                _waveOut.Init(new VisualizerSampleProvider(sampleProvider, ProcessVisualizerSample));

                _waveOut.Volume = volBar.Value / 100f;
                _waveOut.PlaybackStopped += OnPlaybackStopped;
                _waveOut.Play();

                UpdateNowPlaying(_currentSong);

                progressBar1.Maximum = Math.Max(1, (int)_audioReader.TotalTime.TotalSeconds);
                progressBar1.Value = 0;
                lblTotal.Text = _currentSong.DurationText;
                lblCurrent.Text = "0:00";
                btnPlay.Text = "⏸";

                await DatabaseHelper.IncrementPlayCountAsync(_currentSong.SongId);

                HighlightCurrentRow();
                _progressTimer.Start();
                timerWave.Start();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"재생 오류: {ex.Message}");
            }
        }

        private void ProcessVisualizerSample(float sample)
        {
            _complexBuffer[_sampleCount].X =
                sample * FastFourierTransform.HammingWindow(_sampleCount, 512);
            _complexBuffer[_sampleCount].Y = 0;
            _sampleCount++;

            if (_sampleCount < 512)
                return;

            _sampleCount = 0;
            FastFourierTransform.FFT(true, 9, _complexBuffer);

            for (int i = 0; i < 256; i++)
            {
                float real = _complexBuffer[i].X;
                float imaginary = _complexBuffer[i].Y;
                _fftBuffer[i] = (float)Math.Sqrt(real * real + imaginary * imaginary);
            }
        }

        private void StopPlayback()
        {
            _progressTimer?.Stop();
            timerWave?.Stop();

            if (_waveOut != null)
            {
                try
                {
                    _waveOut.PlaybackStopped -= OnPlaybackStopped;
                    _waveOut.Stop();
                }
                catch { }

                _waveOut.Dispose();
                _waveOut = null;
            }

            if (_audioReader != null)
            {
                _audioReader.Dispose();
                _audioReader = null;
            }
        }

        private void OnPlaybackStopped(object sender, StoppedEventArgs e)
        {
            if (!IsHandleCreated || IsDisposed)
                return;

            BeginInvoke((Action)(() =>
            {
                btnPlay.Text = "▶";
                _progressTimer.Stop();

                if (_currentSong == null || _playlist.Count == 0)
                {
                    ResetNowPlaying();
                    return;
                }

                if (_currentIndex + 1 < _playlist.Count)
                    PlaySong(_currentIndex + 1);
                else
                {
                    if (progressBar1.Maximum > 0)
                        progressBar1.Value = 0;
                    lblCurrent.Text = "0:00";
                }
            }));
        }

        private void InitProgressTimer()
        {
            _progressTimer = new System.Windows.Forms.Timer { Interval = 500 };
            _progressTimer.Tick += (s, e) =>
            {
                if (_audioReader == null || _isDragging)
                    return;

                int position = (int)_audioReader.CurrentTime.TotalSeconds;

                if (progressBar1.Maximum > 0)
                    progressBar1.Value = Math.Min(position, progressBar1.Maximum);

                lblCurrent.Text = $"{position / 60}:{position % 60:D2}";
            };
        }

        private void WirePlayerEvents()
        {
            btnPlay.Click += (s, e) =>
            {
                if (_waveOut == null)
                {
                    if (_playlist.Count > 0)
                        PlaySong(0);
                    return;
                }

                if (_waveOut.PlaybackState == PlaybackState.Playing)
                {
                    _waveOut.Pause();
                    btnPlay.Text = "▶";
                    _progressTimer.Stop();
                }
                else
                {
                    _waveOut.Play();
                    btnPlay.Text = "⏸";
                    _progressTimer.Start();
                }
            };

            btnPrev.Click += (s, e) =>
            {
                if (_currentIndex > 0)
                    PlaySong(_currentIndex - 1);
            };

            btnNext.Click += (s, e) =>
            {
                if (_currentIndex < _playlist.Count - 1)
                    PlaySong(_currentIndex + 1);
            };

            volBar.ValueChanged += (s, e) =>
            {
                if (_waveOut != null)
                    _waveOut.Volume = volBar.Value / 100f;
            };

            FormClosing += (s, e) => StopPlayback();
        }

        private void UpdateNowPlaying(SongInfo song)
        {
            lblTitle.Text = song.Title;
            lblArtist.Text = $"{song.Artist}  ·  {(song.Year > 0 ? song.Year.ToString() : "")}";
            SetAlbumArtImage(albumArt, song.AlbumArtUrl);
        }

        private void ResetNowPlaying()
        {
            lblTitle.Text = "재생 중인 곡 없음";
            lblArtist.Text = "";
            albumArt.Image = GetDefaultAlbumArt();
            lblCurrent.Text = "0:00";
            lblTotal.Text = "0:00";
            progressBar1.Value = 0;
            btnPlay.Text = "▶";
        }

        private void timerWave_Tick(object sender, EventArgs e)
        {
            pictureBoxWave.Invalidate();
        }

        private void pictureBoxWave_Paint(object sender, PaintEventArgs e)
        {
            if (_waveOut == null || _waveOut.PlaybackState != PlaybackState.Playing)
            {
                e.Graphics.DrawLine(
                    Pens.DimGray,
                    0,
                    pictureBoxWave.Height / 2,
                    pictureBoxWave.Width,
                    pictureBoxWave.Height / 2);
                return;
            }

            e.Graphics.SmoothingMode = SmoothingMode.AntiAlias;

            const int barWidth = 12;
            const int gap = 2;
            int maximumBars = pictureBoxWave.Width / (barWidth + gap);

            for (int i = 0; i < maximumBars; i++)
            {
                float ratio = (float)i / maximumBars;
                int dataIndex = (int)(Math.Pow(ratio, 1.2) * 255);

                float rawValue = _fftBuffer[Math.Clamp(dataIndex, 0, 255)];
                float boostedValue = (float)Math.Sqrt(rawValue) * 1200;
                float finalValue = boostedValue * (1.0f + ratio * 2.0f);

                int barHeight = (int)Math.Clamp(finalValue, 5, pictureBoxWave.Height - 5);
                int x = i * (barWidth + gap);
                int y = (pictureBoxWave.Height - barHeight) / 2;

                using var brush = new LinearGradientBrush(
                    new Rectangle(x, y, barWidth, barHeight),
                    Color.HotPink,
                    Color.DeepSkyBlue,
                    LinearGradientMode.Vertical);

                e.Graphics.FillRectangle(brush, x, y, barWidth, barHeight);
            }
        }
    }
}
